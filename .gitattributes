# Auto-detect text files and enforce LF in the repository
* text=auto eol=lf

# Force LF for these file types
*.java text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.jsx  text eol=lf
*.js   text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.xml  text eol=lf
*.sh   text eol=lf
mvnw   text eol=lf

# Windows-specific files
*.bat  text eol=crlf
*.cmd  text eol=crlf

# Binary files — do not modify
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.jar  binary
*.war  binary
*.zip  binary
*.svg  text eol=lf
