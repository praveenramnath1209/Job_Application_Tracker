# ========================
# Job Application Tracker — Environment Variables Template
# ========================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your real values below
# 3. NEVER commit the .env file — it is gitignored
# ========================

# ========================
# PostgreSQL Database
# ========================
POSTGRES_DB=jobtracker
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_db_password

# ========================
# Backend Server
# ========================
PORT=8080

# ========================
# JWT Authentication
# Generate a secure secret:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ========================
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_EXPIRATION_MS=86400000

# ========================
# Mail / SMTP
# For Gmail, create an App Password at:
#   https://myaccount.google.com/apppasswords
# ========================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your_gmail_app_password

# ========================
# CORS Allowed Origins (comma-separated, no spaces)
# ========================
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://localhost:5173

# ========================
# Frontend API URL
# ========================
VITE_API_BASE_URL=http://localhost:8080
